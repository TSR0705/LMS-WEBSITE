# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# Read Token (Required for Live Preview of Drafts)
SANITY_API_TOKEN=
# Full Access Admin Token (Required for Webhooks / Server Actions to mutate data)
SANITY_API_ADMIN_TOKEN=

# For Sanity Studio to read (Optional, falls back to NEXT_PUBLIC versions)
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=

# Next.js Base URL (Required for development and absolute links)
# Note: In production, Vercel automatically sets VERCEL_PROJECT_PRODUCTION_URL
NEXT_PUBLIC_BASE_URL=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Set this environment variable to support webhooks — https://stripe.com/docs/webhooks#verify-events
STRIPE_WEBHOOK_SECRET=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=